{
    "name": "akondas/infrasonic",
    "description": "A modern, build-time compiled PHP framework for persistent-worker runtimes. Inspired by Quarkus.",
    "type": "library",
    "keywords": ["framework", "performance", "frankenphp", "compiler", "ahead-of-time"],
    "license": "MIT",
    "authors": [
        {
            "name": "Arkadiusz Kondas",
            "email": "arkadiusz.kondas@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75"
    },
    "autoload": {
        "psr-4": {
            "Infrasonic\\": "src/",
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Infrasonic\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/infra"],
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "cs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --dry-run --diff",
        "cs:fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix",
        "stan": "phpstan analyse",
        "test": "phpunit",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "cs": "Check coding standards (dry-run)",
        "cs:fix": "Fix coding standards",
        "stan": "Run static analysis",
        "test": "Run the test suite",
        "check": "Run the full quality pipeline"
    }
}
